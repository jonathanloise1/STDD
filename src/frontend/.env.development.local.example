# ===========================================
# LOCAL DEVELOPMENT OVERRIDES
# ===========================================
# This file overrides .env.development for local development
# It is NOT committed to git (listed in .gitignore)
#
# Copy this file to .env.local and adjust as needed

# Meta description (already set in .env.development, override if needed)
# VITE_META_DESC="MyApp - Access to dashboard"

# Local redirect URI for authentication
VITE_AZURE_AD_B2C_REDIRECT_URI=http://localhost:3147

# Local API (uncomment if running backend locally)
VITE_API_BASE_URL=https://localhost:7342

# Or use DEV backend (comment the line above and uncomment this)
# VITE_API_BASE_URL=https://myapp-appservice-dev.azurewebsites.net

# ============ DEV AUTH BYPASS (skip Entra External ID login) ============
# Set a user AadId that exists in your local MyApp_DEV database.
# The frontend will skip MSAL and the backend ImpersonationMiddleware
# will create a ClaimsPrincipal from this ID.
# Requires backend appsettings.Development.json: MyApp:Impersonation:Enabled = true
#
# VITE_DEV_MOCK_USER_ID=00000000-0000-0000-0000-000000000001
# VITE_DEV_MOCK_USER_EMAIL=dev@myapp.local
