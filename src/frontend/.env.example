# ===========================================
# MASPLIT FRONTEND — ALL AVAILABLE VARIABLES
# ===========================================
# Copy this file to .env.development or .env.production
# and fill in the values for your environment.
#
# All VITE_* variables are embedded in the browser bundle
# at build time — do NOT put secrets here.
# ===========================================

# ---- App ----
# VITE_SITE_NAME=MyApp
# VITE_META_DESC="MyApp - Access to dashboard"

# ---- Theme ----
# Available: myapp-professional, facit-default
# VITE_THEME=myapp-professional
# VITE_DARK_MODE=false

# ---- Layout ----
# VITE_MOBILE_BREAKPOINT_SIZE=768
# VITE_ASIDE_MINIMIZE_BREAKPOINT_SIZE=1024
# VITE_ASIDE_WIDTH_PX=195
# VITE_SPACER_PX=13
# VITE_MODERN_DESGIN=true
# VITE_ASIDE_TOUCH_STATUS=true

# ---- Theme colors ----
# VITE_PRIMARY_COLOR=#1B4D6E
# VITE_SECONDARY_COLOR=#64748B
# VITE_SUCCESS_COLOR=#059669
# VITE_INFO_COLOR=#0284C7
# VITE_WARNING_COLOR=#D97706
# VITE_DANGER_COLOR=#DC2626
# VITE_LIGHT_COLOR=#F8FAFC
# VITE_DARK_COLOR=#0F172A

# ---- Azure Entra External ID (CIAM) ----
# VITE_AZURE_AD_B2C_CLIENT_ID=YOUR_CLIENT_ID
# VITE_AZURE_AD_B2C_AUTHORITY=https://YOUR_AUTHORITY/YOUR_TENANT_ID/v2.0
# VITE_AZURE_AD_B2C_KNOWN_AUTHORITIES=YOUR_KNOWN_AUTHORITY
# VITE_AZURE_AD_B2C_REDIRECT_URI=http://localhost:3147

# ---- API ----
# VITE_API_SCOPE=https://YOUR_TENANT.onmicrosoft.com/YOUR_API/YOUR_SCOPE
# VITE_API_AUDIENCE=YOUR_API_AUDIENCE
# VITE_API_BASE_URL=https://localhost:7342

# ---- Storybook ----
# VITE_STORYBOOK_URL=http://localhost:6006/?path=
