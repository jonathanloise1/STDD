# ============================================================================
# ROOT .gitignore — MyApp WebApp
# ============================================================================

# ---- OS generated files ----
.DS_Store
Thumbs.db
ehthumbs.db
desktop.ini
$RECYCLE.BIN/

# ---- Visual Studio ----
.vs/
*.suo
*.user
*.userossscache
*.sln.docstates

# ---- VS Code ----
# Uncomment if you don't want to share VS Code settings
# .vscode/

# ---- JetBrains Rider / IntelliJ ----
.idea/

# ---- Vite cache ----
.vite/

# ---- Logs ----
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ---- Node ----
node_modules/

# ---- .NET build output ----
bin/
obj/

# ---- Frontend build output ----
dist/
build/

# ---- Environment files with secrets ----
.env.local
.env.*.local
appsettings.Development.json

# ---- TypeScript build info ----
*.tsbuildinfo
